{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "baseUrl": "./src",
    "paths": {
      "@components": ["components"],
      "@components/*": ["components/*"],
      "@atoms": ["components/atoms"],
      "@atoms/*": ["components/atoms/*"],
      "@molecules": ["components/molecules"],
      "@molecules/*": ["components/molecules/*"],
      "@organisms": ["components/organisms"],
      "@organisms/*": ["components/organisms/*"],
      "@store/*": ["store/*"],
      "@css/*": ["css/*"]
    },
    "composite": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
