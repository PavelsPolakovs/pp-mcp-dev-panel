{
  "name": "pp-mcp-dev-panel",
  "description": "Developer panel for Model Context Protocol — React client (Vite) + Express/WebSocket server",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.10.2",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "i18next": "^26.0.8",
    "lucide-react": "^0.447.0",
    "open": "^10.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-i18next": "^17.0.6",
    "react-router-dom": "^7.14.2",
    "ws": "^8.17.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.6.0",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.2.1",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "postcss": "^8.4.47",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.14",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  },
  "scripts": {
    "dev": "vite build client && concurrently --kill-others-on-fail --names client,server -c blue,green \"vite build client --watch\" \"node --watch server/index.ts\"",
    "build": "vite build client",
    "start": "npm run build && NODE_ENV=production node server/index.ts",
    "lint": "eslint .",
    "typecheck": "tsc -p client/tsconfig.json --noEmit && tsc -p server/tsconfig.json --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "ci": "npm run lint && npm run typecheck && npm run format:check",
    "test": "echo \"No test runner configured\" && exit 1",
    "clean": "rm -rf client/dist server/dist",
    "clean:all": "rm -rf client/dist server/dist node_modules"
  },
  "type": "module"
}
